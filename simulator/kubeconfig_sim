apiVersion: v1
kind: Config
clusters:
- cluster:
    certificate-authority-data: YOUR_CA_DATA
    server: https://YOUR_CLUSTER_ENDPOINT
  name: gke-cluster
contexts:
- context:
    cluster: gke-cluster
    user: gke-user
  name: gke-context
current-context: gke-context
users:
- name: gke-user
  user:
    token: YOUR_GCP_ACCESS_TOKEN
